{
  "name": "@llmassert/playwright",
  "version": "0.1.0",
  "description": "Playwright assertion matchers for testing LLM outputs — groundedness, PII, sentiment, schema, and fuzzy matching",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter.d.ts",
        "default": "./dist/reporter.js"
      },
      "require": {
        "types": "./dist/reporter.d.cts",
        "default": "./dist/reporter.cjs"
      }
    },
    "./fixtures": {
      "import": {
        "types": "./dist/fixtures.d.ts",
        "default": "./dist/fixtures.js"
      },
      "require": {
        "types": "./dist/fixtures.d.cts",
        "default": "./dist/fixtures.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0",
    "@anthropic-ai/sdk": ">=0.50.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.50.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22",
    "eslint": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8",
    "typescript-eslint": "^8.58.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "playwright",
    "llm",
    "testing",
    "assertions",
    "ai",
    "evaluation",
    "groundedness",
    "pii",
    "matchers",
    "qa",
    "quality-assurance",
    "schema-validation",
    "sentiment-analysis",
    "fuzzy-matching"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llm-assert/llm-assert.git",
    "directory": "packages/playwright"
  },
  "homepage": "https://github.com/llm-assert/llm-assert/tree/main/packages/playwright#readme",
  "bugs": {
    "url": "https://github.com/llm-assert/llm-assert/issues"
  },
  "engines": {
    "node": ">=20"
  }
}
