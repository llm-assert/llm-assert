# @llmassert/playwright — Environment Variables
#
# Copy this file and fill in your values:
#   cp .env.example .env
#
# Or set these variables in your CI environment / shell profile.

# ─── Judge API Keys ─────────────────────────────────────────────────
# At least one API key is required for LLM-based assertions.
# If neither is set, all assertions return "inconclusive" (tests pass, not fail).
#
# Fallback chain: GPT-5.4-mini (primary) → Claude Haiku (fallback) → inconclusive

# Primary judge model (GPT-5.4-mini)
OPENAI_API_KEY=sk-...

# Fallback judge model (Claude Haiku) — optional but recommended
# Requires @anthropic-ai/sdk installed as an optional peer dependency
ANTHROPIC_API_KEY=sk-ant-...

# ─── Dashboard Reporter ─────────────────────────────────────────────
# Enables sending evaluation results to the LLMAssert dashboard.
# If omitted, the plugin runs in local-only mode (no ingestion, no error).

LLMASSERT_API_KEY=lma_...

# ─── Debug & Output ─────────────────────────────────────────────────

# Custom output path for the JSON file reporter (optional)
# Default: test-results/llmassert-results.json
LLMASSERT_OUTPUT_FILE=

# Enable verbose debug logging (set to 1 to activate)
LLMASSERT_DEBUG=

# ─── Rate Limiting (optional) ───────────────────────────────────────
# Override default rate-limit parameters for the judge client.
# If unset, sensible defaults are used. Set these to tune for your
# API plan limits or to keep values out of committed source.

# Max requests per minute for judge API calls (default: 60)
LLMASSERT_RATE_LIMIT_RPM=
# Burst capacity for the token bucket (default: 10)
LLMASSERT_RATE_LIMIT_BURST=
# Base delay in ms for exponential backoff on 429 (default: 200)
LLMASSERT_BACKOFF_BASE_MS=
# Max retries on 429 before falling to next provider (default: 3)
LLMASSERT_MAX_429_RETRIES=

# ─── CI Metadata ────────────────────────────────────────────────────
# The reporter auto-detects CI metadata (provider, branch, commit, run URL)
# from standard CI environment variables (GITHUB_ACTIONS, GITLAB_CI, etc.).
# Do NOT set these manually — they are injected by your CI system.
