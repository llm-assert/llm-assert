# LLMAssert Monorepo — Environment Variables
#
# This is the root hub file. Each workspace has its own .env.example:
#
#   apps/dashboard/.env.example       — Supabase, Stripe, app config, E2E testing
#   packages/playwright/.env.example  — Judge API keys, reporter config, debug flags
#
# Quick start:
#   cp apps/dashboard/.env.example apps/dashboard/.env.local
#   # then fill in real values
#
# Or pull from Vercel (if project is linked):
#   cd apps/dashboard && vercel link && vercel env pull .env.local

# ─── Shared API Keys ────────────────────────────────────────────────
# These are used by multiple workspaces (playwright plugin + smoke tests).
# Set them here or in your shell profile — they are NOT loaded from this
# file automatically. Copy to the relevant workspace .env.local or export
# in your shell.

# Primary judge model (GPT-5.4-mini) — used by @llmassert/playwright
OPENAI_API_KEY=sk-...

# Fallback judge model (Claude Haiku) — optional but recommended
# Requires @anthropic-ai/sdk installed as optional peer dependency
ANTHROPIC_API_KEY=sk-ant-...

# ─── Cross-Workspace Notes ──────────────────────────────────────────
# The e2e-smoke/ test harness does NOT have its own .env file or
# .env.example — it reads environment variables from apps/dashboard/.env.local
# automatically (parsed by e2e-smoke/playwright.config.ts).
#
# Ensure apps/dashboard/.env.local contains at minimum:
#   NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   E2E_TEST_EMAIL
#   E2E_TEST_PASSWORD
#
# See apps/dashboard/.env.example for full documentation of these vars.
