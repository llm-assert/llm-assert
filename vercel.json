{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/reset-evaluations",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/reconcile",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/ghost-audit",
      "schedule": "0 2 * * *"
    }
  ]
}
