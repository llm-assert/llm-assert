# LLMAssert Dashboard — Environment Variables
#
# Setup:
#   cp .env.example .env.local    # then fill in real values
#
# Or pull from Vercel (if project is linked):
#   vercel env pull .env.local
#
# IMPORTANT: NEXT_PUBLIC_ vars are inlined at BUILD TIME — they do not
# change between requests. Set them correctly per environment in the
# Vercel dashboard (production vs preview vs development).

# ─── Supabase ────────────────────────────────────────────────────────

# Project URL (Dashboard > Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable (anon) key (Dashboard > Settings > API > anon/public key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — bypasses RLS, used for ingest + webhook write paths
# NEVER prefix with NEXT_PUBLIC_ — this key has full database access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ──────────────────────────────────────────────────────────

# Secret key (Dashboard > Developers > API keys)
# Use sk_test_ for development, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret (Dashboard > Developers > Webhooks > Signing secret)
# Each webhook endpoint has its own secret — use the one for /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App Config ──────────────────────────────────────────────────────

# Canonical app URL — used for OAuth redirect host validation
# in app/auth/callback/route.ts (open-redirect protection).
# Must match the deployment URL per environment:
#   Development: http://localhost:3000
#   Preview:     https://llmassert-dashboard-<hash>.vercel.app (set per-branch in Vercel)
#   Production:  https://llmassert-dashboard.vercel.app (or custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job verification secret — random 32+ character hex string
# Used to verify Vercel Cron requests: Authorization: Bearer $CRON_SECRET
# Generate with: openssl rand -hex 32
CRON_SECRET=
