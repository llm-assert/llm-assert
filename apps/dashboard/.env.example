# LLMAssert Dashboard — Environment Variables
# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# After linking to Vercel, pull env vars with:
#   vercel env pull .env.local

# ============================================================
# PUBLIC — Inlined at build time, safe for browser (NEXT_PUBLIC_ prefix)
# ============================================================

# Supabase project URL (from Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable/anon key (from Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Canonical app URL — used for OAuth redirect host validation in auth callback
# Set to your Vercel production URL (e.g., https://llmassert-dashboard.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# SERVER-ONLY — Never exposed to the browser
# ============================================================

# Supabase service role key — bypasses RLS, used for ingest + webhook write paths
# NEVER use NEXT_PUBLIC_ prefix for this value
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe secret key (from Stripe dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (from Stripe dashboard > Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Cron job verification secret — random 32+ character hex string
# Used to verify Vercel Cron requests via Authorization header
CRON_SECRET=

# ============================================================
# OPTIONAL — Not required for basic operation
# ============================================================

# Override Node.js environment (defaults to "development" locally)
# NODE_ENV=development
