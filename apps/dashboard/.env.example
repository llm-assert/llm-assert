# LLMAssert Dashboard — Environment Variables
#
# Setup:
#   cp .env.example .env.local    # then fill in real values
#
# Or pull from Vercel (if project is linked):
#   cd apps/dashboard && vercel link && vercel env pull .env.local
#
# IMPORTANT: NEXT_PUBLIC_ vars are inlined at BUILD TIME — they do not
# change between requests. Set them correctly per environment in the
# Vercel dashboard (production vs preview vs development).

# ─── Supabase ────────────────────────────────────────────────────────
# Targets: all (production, preview, development)

# PUBLIC — Project URL (Dashboard > Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# PUBLIC — Publishable (anon) key (Dashboard > Settings > API > anon/public key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVER-ONLY — Service role key — bypasses RLS, used for ingest + webhook write paths
# NEVER prefix with NEXT_PUBLIC_ — this key has full database access
# Targets: production + preview (encrypted)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ──────────────────────────────────────────────────────────

# SERVER-ONLY — Secret key (Dashboard > Developers > API keys)
# Use sk_test_ for development. Production uses sk_live_ after FEAT-43 cutover.
# Targets: production only (encrypted) — preview deployments cannot make Stripe API calls
STRIPE_SECRET_KEY=sk_test_...

# SERVER-ONLY — Webhook signing secret for /api/webhooks/stripe
#
# LOCAL DEVELOPMENT:
#   Run `pnpm stripe:listen` — the CLI prints a signing secret (whsec_...).
#   Copy it here. This secret is stable across CLI restarts.
#
# PRODUCTION:
#   Use the signing secret from Stripe Dashboard > Developers > Webhooks >
#   your endpoint's signing secret. This is DIFFERENT from the CLI secret.
#
# Targets: production (encrypted), development (from Stripe CLI)
STRIPE_WEBHOOK_SECRET=whsec_...

# PUBLIC — Publishable key for Stripe.js client-side
# Targets: all (production, preview, development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SERVER-ONLY — Stripe price IDs for subscription tiers
# These differ between test mode and live mode — set correct IDs per environment
# Targets: production + preview
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ─── App Config ──────────────────────────────────────────────────────

# PUBLIC — Canonical app URL — used for OAuth redirect host validation
# in app/auth/callback/route.ts (open-redirect protection).
#
# Per-environment:
#   Production:  https://llmassert.com
#   Preview:     Derived automatically from VERCEL_URL — do not set in preview
#   Development: http://localhost:3000
#
# Targets: production only (preview uses VERCEL_URL fallback)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── E2E Testing ────────────────────────────────────────────────────
# Used by Playwright E2E tests (apps/dashboard/e2e/)
# These are NOT needed for development — only for running E2E tests

# Email for the ephemeral test user (created via Supabase Admin API in setup)
E2E_TEST_EMAIL=test-e2e@llmassert.local

# Password for the ephemeral test user
E2E_TEST_PASSWORD=

# Base URL for the dashboard (default: http://localhost:3000)
E2E_BASE_URL=http://localhost:3000

# ─── Cron ────────────────────────────────────────────────────────────
# SERVER-ONLY — Cron job verification secret
# Used to verify Vercel Cron requests: Authorization: Bearer $CRON_SECRET
# Generate with: openssl rand -hex 32 (must be at least 64 hex characters)
# Targets: production only (encrypted) — cron jobs only run on production
CRON_SECRET=
